# ── Supabase ──────────────────────────────────────────────────────────────────
# URL pública — se incluye en el bundle del cliente (Next.js la expone al browser)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# URL privada — usada solo por createAdminClient() en server-side (no se expone al cliente)
# Mismo valor que NEXT_PUBLIC_SUPABASE_URL pero sin prefijo NEXT_PUBLIC_
SUPABASE_URL=https://tu-proyecto.supabase.co

# Service role key — bypasea RLS, NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── IA ────────────────────────────────────────────────────────────────────────
# Motor principal (Together AI) — modelo configurado en src/lib/ai/client.ts
TOGETHER_API_KEY=...
# Fallback opcional cuando Together no está disponible
GROQ_API_KEY=...
# Embeddings para búsqueda semántica (RAG sobre pgvector)
VOYAGE_API_KEY=pa-...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtener en resend.com/api-keys
RESEND_API_KEY=re_...
# Requiere DNS verificado en resend.com/domains
EMAIL_FROM=APIP <notificaciones@mail.aicounts.cl>

# ── Inngest ───────────────────────────────────────────────────────────────────
# Obtener en app.inngest.com → tu app → Signing Key / Event Key
INNGEST_SIGNING_KEY=signkey-prod-...
INNGEST_EVENT_KEY=...

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Secret para el endpoint /api/escalacion (llamado por GitHub Actions cron)
# Generar con: openssl rand -hex 32
ESCALACION_SECRET=cambia-este-secret-en-produccion

# Secret para el endpoint /api/admin/reprocesar-documentos
# NUNCA usar SUPABASE_SERVICE_ROLE_KEY aquí — generar uno dedicado:
# openssl rand -hex 32
ADMIN_REPROCESAR_SECRET=cambia-este-secret-en-produccion

# ── Producción ────────────────────────────────────────────────────────────────
# URL pública de la app desplegada (Railway, Vercel, etc.)
# Usada por el cron de escalación en GitHub Actions
APP_URL=https://tu-dominio.railway.app
